# Environment — never commit real keys
.env

# Personal resume files — add your own to docs/
docs/*.pdf
docs/*.docx
docs/*.doc
docs/*.txt
# Keep the setup README but ignore everything else in docs/
!docs/README.md

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Generated output
outputs/
*.aux
*.log
*.out
*.xdv

# OS
.DS_Store
Thumbs.db
desktop.ini
