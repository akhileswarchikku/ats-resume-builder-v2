# ---- OpenRouter (required) ----
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_APP_TITLE=ATS Resume Builder
OPENROUTER_HTTP_REFERER=http://localhost:8001

# ---- Model ----
# Gemini 2.5 Flash is fast and cheap — swap for any OpenRouter model
LLM_MODEL=google/gemini-2.5-flash

# ---- Paths ----
# Where your resume/portfolio docs live (relative to project root)
DOCS_DIR=./docs
# Where saved applications are written
APPLIES_DIR=./outputs/applies

# ---- Server ----
API_PORT=8001
